{
  "name": "kairos-army-builder",
  "version": "1.0.0",
  "main": "server/dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsc -p server/tsconfig.json --watch & nodemon server/dist/server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node server/dist/server.js"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.20.0",
    "@google/generative-ai": "^0.24.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-jwt": "^8.5.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jwks-rsa": "^4.0.1",
    "knex": "^2.5.1",
    "openai": "^6.45.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "react-router-dom": "^7.18.1",
    "sqlite3": "^5.1.6",
    "superagent": "^10.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/superagent": "^8.1.9",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^8.1.3"
  }
}
